# ==============================================================================
# CreatorOS — Production Environment Configuration Template
# Copy this file to .env.local and fill in the required keys before running.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. APPLICATION & SYSTEM ENVIRONMENT
# ------------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://creatoros.ai
PORT=3000

# ------------------------------------------------------------------------------
# 2. CORE INFRASTRUCTURE (Required in Production)
# ------------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL="postgresql://creatoros_admin:SECURE_PASSWORD@postgres.internal:5432/creatoros_prod?sslmode=require"

# Redis connection string for caching & rate limiting
REDIS_URL="redis://:SECURE_REDIS_PASSWORD@redis.internal:6379"

# ------------------------------------------------------------------------------
# 3. AUTHENTICATION (Required in Production)
# ------------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-character-secret-key-here"
NEXTAUTH_URL="https://creatoros.ai"

# ------------------------------------------------------------------------------
# 4. AI PROVIDERS (Modular Failover Chain)
# ------------------------------------------------------------------------------
# OpenAI API Key (GPT-4o, DALL-E 3, Whisper)
OPENAI_API_KEY="sk-proj-..."

# Google Gemini API Key (Gemini 1.5 Pro, Flash, Imagen 3)
GEMINI_API_KEY="AIzaSy..."

# Anthropic Claude API Key (Claude 3.5 Sonnet, Haiku)
ANTHROPIC_API_KEY="sk-ant-..."

# Groq API Key (LLaMA 3.3 70B Versatile, Whisper Large v3)
GROQ_API_KEY="gsk_..."

# DeepSeek API Key (DeepSeek-R1 Reasoning)
DEEPSEEK_API_KEY="sk-..."

# Fal.ai API Key (Flux Realism & Pro Models)
FAL_KEY="fal_..."

# Replicate API Token (Flux Schnell & Custom Models)
REPLICATE_API_TOKEN="r8_..."

# ElevenLabs API Key (High-Quality Text-To-Speech)
ELEVENLABS_API_KEY="sk_..."

# Deepgram API Key (Nova-2 Speech-To-Text & Subtitles)
DEEPGRAM_API_KEY="..."

# ------------------------------------------------------------------------------
# 5. CLOUD STORAGE (Media Assets & CDN)
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="creatoros-cdn"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="abcdefghijklmnopqrstuvwxyz123456"
